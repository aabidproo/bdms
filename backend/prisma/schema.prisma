// LifeLink - Prisma Schema
// Blood Donation Management System

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── User Model ─────────────────────────────────────────
// Note: SQLite doesn't support native enums.
// Role values (DONOR, RECIPIENT, ADMIN) are validated 
// at the application level via Zod.

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   // DONOR | RECIPIENT | ADMIN
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  resetToken       String?  @unique
  resetTokenExpiry DateTime?

  // 1:1 Relations
  donorProfile     DonorProfile?
  recipientProfile RecipientProfile?

  // 1:N Relations
  requests         BloodRequest[]
}

// ─── Donor Profile (1:1 with User) ──────────────────────

model DonorProfile {
  id               String    @id @default(cuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  phone            String
  dateOfBirth      DateTime
  gender           String
  address          String
  bloodType        String
  weight           Float
  lastDonationDate DateTime?
  medicalCondition String?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// ─── Recipient Profile (1:1 with User) ──────────────────

model RecipientProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  phone            String
  address          String
  bloodType        String
  medicalCondition String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ─── Blood Inventory ────────────────────────────────────

model BloodStock {
  id           String   @id @default(cuid())
  bloodGroup   String   // A+, A-, B+, B-, AB+, AB-, O+, O-
  units        Int
  rbcCount     Float?   // Red Blood Cell count
  plasmaCount  Float?   // Plasma units in mL
  donationDate DateTime
  expiryDate   DateTime
  donorName    String?
  status       String   // Available, Low, Critical
  healthIndicator String @default("Good") // Excellent, Good, Fair, Poor
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Blood Request ──────────────────────────────────────

model BloodRequest {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  bloodGroup   String
  units        Int
  urgency      String   // Normal, Urgent, Critical
  status       String   @default("PENDING") // PENDING, APPROVED, REJECTED, FULFILLED
  hospital     String
  notes        String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
